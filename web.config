<?xml version="1.0" encoding="UTF-8"?>
<!--
  IronBark — IIS configuration
  Drop this file in the site root on the Web Server VM (10.0.1.100).

  Approach: HttpPlatformHandler launches `waitress-serve` (a production WSGI
  server), and IIS reverse-proxies all requests to it on a local port.

  PREREQS on the Web Server VM:
    1. Install Python 3.11+ (e.g., to C:\Python311).
    2. Install IIS HttpPlatformHandler:
       https://www.iis.net/downloads/microsoft/httpplatformhandler
    3. Create a venv at C:\inetpub\ironbark\venv, pip install -r requirements.txt
    4. Place .env in the app root (C:\inetpub\ironbark\.env) with real values.
    5. Grant the app pool identity "Read" on C:\inetpub\ironbark (NOT Write).
-->
<configuration>

  <system.webServer>

    <!-- Launch waitress as our WSGI server. IIS proxies to it. -->
    <handlers>
      <add name="httpPlatformHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>

    <httpPlatform
        processPath="C:\inetpub\ironbark\venv\Scripts\waitress-serve.exe"
        arguments="--listen=127.0.0.1:%HTTP_PLATFORM_PORT% --call app:app"
        stdoutLogEnabled="true"
        stdoutLogFile="C:\inetpub\ironbark\logs\stdout"
        startupTimeLimit="60"
        processesPerApplication="1">
      <environmentVariables>
        <environmentVariable name="PYTHONUNBUFFERED" value="1" />
        <environmentVariable name="PYTHONPATH" value="C:\inetpub\ironbark" />
      </environmentVariables>
    </httpPlatform>

    <!--
      Block direct access to sensitive files.
      The Red Team WILL try /.env, /app.py, /database/db.py, etc.
    -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment=".env" />
          <add segment=".env.example" />
          <add segment=".git" />
          <add segment="__pycache__" />
          <add segment="venv" />
          <add segment="database" />
          <add segment="docs" />
          <add segment="logs" />
        </hiddenSegments>
        <fileExtensions>
          <add fileExtension=".py" allowed="false" />
          <add fileExtension=".pyc" allowed="false" />
          <add fileExtension=".env" allowed="false" />
          <add fileExtension=".sql" allowed="false" />
          <add fileExtension=".md" allowed="false" />
          <add fileExtension=".log" allowed="false" />
          <add fileExtension=".config" allowed="false" />
        </fileExtensions>
        <!-- Cap request body to match Flask's MAX_CONTENT_LENGTH -->
        <requestLimits maxAllowedContentLength="262144" />
      </requestFiltering>
    </security>

    <!-- Remove server fingerprinting headers -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Ironbark-Node" value="NODE-01" />
      </customHeaders>
    </httpProtocol>

    <!-- Disable directory browsing -->
    <directoryBrowse enabled="false" />

    <!-- Custom error pages hide stack traces from attackers -->
    <httpErrors errorMode="Custom" existingResponse="PassThrough" />

  </system.webServer>
</configuration>
