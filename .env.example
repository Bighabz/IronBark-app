# ============================================================
# IronBark Security Solutions — Environment Configuration
# ============================================================
# COPY THIS FILE TO .env AND FILL IN REAL VALUES.
# DO NOT COMMIT .env TO GIT OR ANY SHARED LOCATION.
# THE RED TEAM WILL LOOK FOR THIS FILE. IIS IS CONFIGURED TO BLOCK IT.
# ============================================================

# Flask session signing key — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace_with_64_random_hex_characters

# Set to "development" locally to relax Secure cookie flag. Leave blank in prod.
FLASK_ENV=

# ------------------------------------------------------------
# Database VM (10.0.1.200)
# ------------------------------------------------------------
# DB_ENGINE: "mysql" or "mssql"
DB_ENGINE=mysql
DB_HOST=10.0.1.200
DB_PORT=3306
DB_NAME=ironbark
DB_USER=ironbark_app
DB_PASSWORD=replace_with_strong_password

# If using MSSQL, specify the ODBC driver name installed on the web server:
DB_ODBC_DRIVER=ODBC Driver 17 for SQL Server

# ------------------------------------------------------------
# AI API (CSUSB university API, OR OpenAI directly — same payload shape)
# ------------------------------------------------------------
# If using OpenAI directly:
#   UNIVERSITY_AI_API_URL=https://api.openai.com/v1/chat/completions
#   UNIVERSITY_AI_API_KEY=sk-...
#   UNIVERSITY_AI_MODEL=gpt-4o-mini
# NEVER hardcode the key. Paste it directly into this .env file on the server,
# not into any chat or PR. IIS is configured to return 404 on /.env requests.
UNIVERSITY_AI_API_URL=https://api.openai.com/v1/chat/completions
UNIVERSITY_AI_API_KEY=replace_with_openai_or_csusb_key
UNIVERSITY_AI_MODEL=gpt-4o-mini

# Global AI budget — total calls across ALL visitors per window. Protects
# the API key from runaway cost if per-IP rate limits are bypassed via
# rotating IPs. Default: 500/day, 100/hour. Lower if you're worried.
AI_BUDGET_DAILY=500
AI_BUDGET_HOURLY=100

# ------------------------------------------------------------
# Admin basic auth (for /api/admin/submissions demo endpoint)
# ------------------------------------------------------------
ADMIN_BASIC_USER=admin
ADMIN_BASIC_PASS=replace_with_strong_password
